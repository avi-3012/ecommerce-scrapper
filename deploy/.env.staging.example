# Staging secrets template (WP-0.5) — copy to deploy/.env.staging ON THE VPS,
# fill with real values, chmod 600. Never committed.

SITE_HOSTNAME=staging.pricepulse.example.com

REGISTRY=ghcr.io/OWNER/REPO
TAG=v0.1.0

POSTGRES_USER=pricepulse
POSTGRES_PASSWORD=<openssl rand -hex 24>
POSTGRES_DB=pricepulse
DATABASE_URL=postgresql://pricepulse:<same-password>@db:5432/pricepulse

JWT_SECRET=<openssl rand -hex 32>
SETTINGS_ENC_KEY=<openssl rand -hex 32>
