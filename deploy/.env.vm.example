# PricePulse single-VM demo env — copy to deploy/.env.vm ON THE VM and fill in.
# Never commit the real .env.vm (it's gitignored).

# ── Database (compose creates this Postgres; pick any password) ──
POSTGRES_USER=pricepulse
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=pricepulse
# Must match the three values above; host is the compose service name "db".
DATABASE_URL=postgresql://pricepulse:CHANGE_ME_db_password@db:5432/pricepulse

# ── App secrets ──
NODE_ENV=production
# Session signing key — any long random string (openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
# Telegram-token encryption key — EXACTLY 32 bytes hex / 64 chars (openssl rand -hex 32)
SETTINGS_ENC_KEY=CHANGE_ME_64_hex_chars

# Plain-HTTP demo on a bare IP (no domain/TLS): keep false so login works.
# Set to true only once you serve over HTTPS behind a domain.
COOKIE_SECURE=false

# ── Login account (seeded on first deploy) ──
SEED_USER_EMAIL=admin@yourdomain.com
SEED_USER_PASSWORD=CHANGE_ME_strong_password

# ── Worker tuning (defaults are fine) ──
WORKER_HEARTBEAT_SECONDS=30
SCHEDULER_TICK_SECONDS=20
